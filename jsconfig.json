{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./client/src/*"
      ]
    },
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "checkJs": false,
    "strict": false
  },
  "include": [
    "client/src/**/*"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "client/dist"
  ]
}